{
    "id": null,
    "uid": "logs-overview",
    "title": "Logs Overview",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 2,
    "refresh": "30s",
    "panels": [
        {
            "type": "timeseries",
            "title": "App Error Lines (5m)",
            "datasource": "Loki",
            "targets": [
                {
                    "expr": "sum(count_over_time({job=\"docker\",service=\"app\"} |~ \"(?i)error\" [5m]))",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "decimals": 0
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            }
        },
        {
            "type": "timeseries",
            "title": "Nginx 5xx Lines (5m)",
            "datasource": "Loki",
            "targets": [
                {
                    "expr": "sum(count_over_time({job=\"nginx\"} |~ \"HTTP/[0-9.]+\\\" 5[0-9]{2} \" [5m]))",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "decimals": 0
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            }
        },
        {
            "type": "logs",
            "title": "App Logs",
            "datasource": "Loki",
            "targets": [
                {
                    "expr": "{job=\"docker\",service=\"app\"}",
                    "refId": "A"
                }
            ],
            "options": {
                "showLabels": true,
                "showTime": true,
                "wrapLogMessage": true,
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "sortOrder": "Descending"
            },
            "gridPos": {
                "h": 12,
                "w": 12,
                "x": 0,
                "y": 8
            }
        },
        {
            "type": "logs",
            "title": "Nginx Logs",
            "datasource": "Loki",
            "targets": [
                {
                    "expr": "{job=\"nginx\"}",
                    "refId": "A"
                }
            ],
            "options": {
                "showLabels": true,
                "showTime": true,
                "wrapLogMessage": true,
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "sortOrder": "Descending"
            },
            "gridPos": {
                "h": 12,
                "w": 12,
                "x": 12,
                "y": 8
            }
        },
        {
            "type": "timeseries",
            "title": "AI Agents vs Humans (5m)",
            "description": "Nginx requests split between known AI crawlers and everyone else. Agent detection is based on User-Agent strings — agents that don't identify themselves appear as humans.",
            "datasource": "Loki",
            "targets": [
                {
                    "expr": "sum(count_over_time({job=\"nginx\"} |~ \"(?i)(GPTBot|ClaudeBot|Anthropic-AI|PerplexityBot|CCBot|meta-externalagent|Googlebot|bingbot|AhrefsBot|DataForSeoBot|Bytespider|DuckDuckBot|amazonbot|applebot|Twitterbot|LinkedInBot|WhatsApp)\" [5m]))",
                    "refId": "A",
                    "legendFormat": "AI Agents"
                },
                {
                    "expr": "sum(count_over_time({job=\"nginx\"} !~ \"(?i)(GPTBot|ClaudeBot|Anthropic-AI|PerplexityBot|CCBot|meta-externalagent|Googlebot|bingbot|AhrefsBot|DataForSeoBot|Bytespider|DuckDuckBot|amazonbot|applebot|Twitterbot|LinkedInBot|WhatsApp)\" [5m]))",
                    "refId": "B",
                    "legendFormat": "Humans (or unidentified bots)"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "short",
                    "decimals": 0
                },
                "overrides": [
                    {
                        "matcher": { "id": "byName", "options": "AI Agents" },
                        "properties": [
                            { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
                        ]
                    },
                    {
                        "matcher": { "id": "byName", "options": "Humans (or unidentified bots)" },
                        "properties": [
                            { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
                        ]
                    }
                ]
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 20
            }
        }
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-6h",
        "to": "now"
    },
    "annotations": {
        "list": []
    },
    "editable": true,
    "graphTooltip": 0,
    "links": []
}