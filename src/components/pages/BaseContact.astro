---
import type { SupportedLanguage } from '../../types/i18n';

export interface ContactTranslations {
    pageTitle: string;
    pageDescription: string;
    formLabels: {
        reason: string;
        blogPostTitle: string;
        name: string;
        email: string;
        message: string;
    };
    reasonOptions: {
        select: string;
        problems: string;
        consultancy: string;
        mentoring: string;
        job: string;
        blogpost: string;
        general: string;
    };
    buttons: {
        submit: string;
        submitting: string;
        openGitHubIssue: string;
    };
    prefillMessages: {
        consultancy: string;
        mentoring: string;
        job: string;
        blogpost: string;
    };
    alerts: {
        fillRequired: string;
        success: string;
        error: string;
        networkError: string;
    };
}

export const contactTranslations: Record<SupportedLanguage, ContactTranslations> = {
    en: {
        pageTitle: 'Contact',
        pageDescription:
            'Get in touch with Alessandro Romano for consultancy, mentoring, job opportunities, or general inquiries about software engineering and leadership.',
        formLabels: {
            reason: 'Reason',
            blogPostTitle: 'Blog Post Title',
            name: 'Name',
            email: 'Email',
            message: 'Message',
        },
        reasonOptions: {
            select: 'Select a reason...',
            problems: 'Problems on the website',
            consultancy: 'Consultancy request',
            mentoring: 'Mentoring',
            job: 'Job opportunities',
            blogpost: 'Blog Post Feedback',
            general: 'General inquiry',
        },
        buttons: {
            submit: 'Submit',
            submitting: 'Submitting...',
            openGitHubIssue: 'Open GitHub Issue',
        },
        prefillMessages: {
            consultancy:
                'Before reaching out, please review my LinkedIn profile (https://www.linkedin.com/in/aleromano92/). Then tell me why you think I could help your company, with a link for more details.',
            mentoring: "Tell me why you think I could be of help and I'll happily do my best.",
            job: 'Before reaching out, please review my LinkedIn profile (https://www.linkedin.com/in/aleromano92/). Then tell me why I could be a good fit, with a link for more details.',
            blogpost: 'Share your thoughts, feedback, or questions about this post — I appreciate constructive discussions!',
        },
        alerts: {
            fillRequired: 'Please fill in all required fields: Name, Email, and Message.',
            success: 'Your message has been sent successfully!',
            error: 'An error occurred. Please try again.',
            networkError: 'An unexpected error occurred. Please check your connection and try again.',
        },
    },
    it: {
        pageTitle: 'Contatti',
        pageDescription:
            'Contatta Alessandro Romano per consulenza, mentoring, opportunità di lavoro o domande generali su ingegneria del software e leadership.',
        formLabels: {
            reason: 'Motivo',
            blogPostTitle: 'Titolo del Post',
            name: 'Nome',
            email: 'Email',
            message: 'Messaggio',
        },
        reasonOptions: {
            select: 'Seleziona un motivo...',
            problems: 'Problemi sul sito web',
            consultancy: 'Richiesta di consulenza',
            mentoring: 'Mentoring',
            job: 'Opportunità di lavoro',
            blogpost: 'Feedback su articolo',
            general: 'Domanda generale',
        },
        buttons: {
            submit: 'Invia',
            submitting: 'Invio in corso...',
            openGitHubIssue: 'Apri Issue su GitHub',
        },
        prefillMessages: {
            consultancy:
                "Prima di contattarmi, dai un'occhiata al mio profilo LinkedIn (https://www.linkedin.com/in/aleromano92/). Poi scrivimi perché pensi che potrei aiutare la tua azienda, con un link per approfondire.",
            mentoring: "Scrivimi perché pensi che potrei esserti d'aiuto e farò del mio meglio.",
            job: "Prima di contattarmi, dai un'occhiata al mio profilo LinkedIn (https://www.linkedin.com/in/aleromano92/). Poi scrivimi perché sarei adatto alla tua azienda, con un link per approfondire.",
            blogpost:
                'Condividi pensieri, feedback o domande su questo articolo — apprezzo confronti costruttivi e discussioni interessanti!',
        },
        alerts: {
            fillRequired: 'Compila tutti i campi obbligatori: Nome, Email e Messaggio.',
            success: 'Il tuo messaggio è stato inviato con successo!',
            error: 'Si è verificato un errore. Riprova.',
            networkError: 'Si è verificato un errore imprevisto. Controlla la connessione e riprova.',
        },
    },
};

export function getContactTranslations(language: SupportedLanguage): ContactTranslations {
    return contactTranslations[language];
}

interface Props {
    language: SupportedLanguage;
}

const { language } = Astro.props;

// Get translations for the current language
const t = getContactTranslations(language);
---

<div class="contact-form-container">
    <form id="contactForm">
        <div class="form-group">
            <label for="contactReason">{t.formLabels.reason}</label>
            <div class="select-wrapper">
                <select id="contactReason" name="reason">
                    <option value="">{t.reasonOptions.select}</option>
                    <option value="problems">{t.reasonOptions.problems}</option>
                    <option value="consultancy">{t.reasonOptions.consultancy}</option>
                    <option value="mentoring">{t.reasonOptions.mentoring}</option>
                    <option value="job">{t.reasonOptions.job}</option>
                    <option value="blogpost">{t.reasonOptions.blogpost}</option>
                    <option value="general">{t.reasonOptions.general}</option>
                </select>
            </div>
            <p id="reasonHelper" class="reason-helper" hidden></p>
        </div>

        <div class="form-group" id="blogPostTitleGroup" style="display: none;">
            <label for="blogPostTitle">{t.formLabels.blogPostTitle}</label>
            <input type="text" id="blogPostTitle" name="blogPostTitle" />
        </div>

        <fieldset id="formFields" disabled>
            <div class="form-group">
                <label for="name">{t.formLabels.name}</label>
                <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
                <label for="email">{t.formLabels.email}</label>
                <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
                <label for="message">{t.formLabels.message}</label>
                <textarea id="message" name="message" rows="5" required></textarea>
            </div>

            <button type="submit" class="button">{t.buttons.submit}</button>
        </fieldset>
    </form>

    <div id="githubIssueButtonContainer" style="display: none;">
        <a
            href="https://github.com/aleromano92/aleromano.com/issues/new"
            target="_blank"
            rel="noopener noreferrer"
            class="button"
        >
            {t.buttons.openGitHubIssue}
        </a>
    </div>

    <p id="formStatus" class="form-status" role="status" hidden></p>
</div>

<script is:inline define:vars={{ t }}>
    const contactReasonSelect = document.getElementById('contactReason');
    const formFields = document.getElementById('formFields');
    const githubIssueButtonContainer = document.getElementById('githubIssueButtonContainer');
    const contactForm = document.getElementById('contactForm');
    const submitButton = contactForm.querySelector('button[type="submit"]');
    const blogPostTitleInput = document.getElementById('blogPostTitle');
    const blogPostTitleGroup = document.getElementById('blogPostTitleGroup');
    const formStatus = document.getElementById('formStatus');

    function showStatus(message, type) {
        formStatus.textContent = message;
        formStatus.classList.remove('success', 'error');
        formStatus.classList.add(type);
        formStatus.hidden = false;
    }

    function hideStatus() {
        formStatus.hidden = true;
        formStatus.textContent = '';
    }

    const reasonHelper = document.getElementById('reasonHelper');

    const HELPER_MESSAGES = {
        consultancy: t.prefillMessages.consultancy,
        mentoring: t.prefillMessages.mentoring,
        job: t.prefillMessages.job,
        blogpost: t.prefillMessages.blogpost,
    };

    function renderHelper(reason) {
        const helperText = HELPER_MESSAGES[reason];
        if (!helperText) {
            reasonHelper.hidden = true;
            reasonHelper.textContent = '';
            return;
        }
        reasonHelper.textContent = helperText;
        // Linkify bare URLs after textContent has neutralized any markup
        reasonHelper.innerHTML = reasonHelper.innerHTML.replace(
            /https?:\/\/[^\s)]+/g,
            (url) => `<a href="${url}" target="_blank" rel="noopener noreferrer">${url}</a>`
        );
        reasonHelper.hidden = false;
    }

    const MESSAGE_REASONS = ['consultancy', 'mentoring', 'job', 'blogpost', 'general'];

    // Only toggles what is enabled/visible for the reason; never touches what the user typed
    function applyReasonVisibility(reason) {
        // 'problems' goes to GitHub instead: the message form would be pure noise
        formFields.style.display = reason === 'problems' ? 'none' : '';
        formFields.disabled = !MESSAGE_REASONS.includes(reason);
        githubIssueButtonContainer.style.display = reason === 'problems' ? 'block' : 'none';
        blogPostTitleGroup.style.display = reason === 'blogpost' ? 'block' : 'none';

        renderHelper(reason);
    }

    function resetForm() {
        contactForm.reset();
        contactReasonSelect.value = '';
        applyReasonVisibility('');
    }

    contactReasonSelect.addEventListener('change', () => {
        hideStatus();
        applyReasonVisibility(contactReasonSelect.value);
    });

    contactForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const formData = new FormData(contactForm);
        const data = Object.fromEntries(formData.entries());

        // A preserved-but-hidden title must not leak into unrelated submissions
        if (data.reason !== 'blogpost') {
            delete data.blogPostTitle;
        }

        if (!formFields.disabled) {
            if (!data.name || !data.email || !data.message) {
                showStatus(t.alerts.fillRequired, 'error');
                return;
            }
        }

        hideStatus();

        if (submitButton) {
            submitButton.disabled = true;
            submitButton.textContent = t.buttons.submitting;
        }

        let feedbackMessage = '';
        let isSuccess = false;

        try {
            const response = await fetch('/api/contact', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(data),
            });

            const result = await response.json();

            if (response.ok && result.success) {
                feedbackMessage = result.message || t.alerts.success;
                isSuccess = true;
                resetForm();
            } else {
                feedbackMessage = result.message || t.alerts.error;
            }
        } catch (error) {
            console.error('Error submitting contact form:', error);
            feedbackMessage = t.alerts.networkError;
        }

        if (submitButton) {
            submitButton.disabled = false;
            submitButton.textContent = t.buttons.submit;
        }

        showStatus(feedbackMessage, isSuccess ? 'success' : 'error');
    });

    document.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const preselectedReason = urlParams.get('reason');
        const prefilledTitle = urlParams.get('title');

        const validReasons = ['consultancy', 'mentoring', 'job', 'blogpost', 'general', 'problems'];
        if (preselectedReason && validReasons.includes(preselectedReason)) {
            contactReasonSelect.value = preselectedReason;

            if (preselectedReason === 'blogpost' && prefilledTitle) {
                blogPostTitleInput.value = decodeURIComponent(prefilledTitle);
            }
        }

        applyReasonVisibility(contactReasonSelect.value);
    });
</script>

<style>
    @import '../../styles/buttons.css';

    .contact-form-container {
        max-width: 600px;
        margin: var(--space-lg) auto;
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        padding: var(--space-lg);
        color: var(--color-text);
    }

    fieldset {
        border: none;
        padding: 0;
        margin: 0;
        transition: opacity 0.3s ease;
    }

    fieldset:disabled {
        opacity: 0.45;
    }

    .form-group {
        margin-bottom: var(--space-md);
    }

    label {
        display: block;
        margin-bottom: var(--space-xs);
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-sm);
        color: var(--color-text-primary);
    }

    input[type='text'],
    input[type='email'],
    select,
    textarea {
        width: 100%;
        padding: var(--space-xs) var(--space-sm);
        border: 1px solid var(--color-border-light);
        border-radius: var(--border-radius-sm);
        background-color: var(--color-bg);
        color: var(--color-text);
        font: inherit;
        line-height: var(--line-height-base);
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    input[type='text']:hover,
    input[type='email']:hover,
    select:hover,
    textarea:hover {
        border-color: var(--color-accent);
    }

    input[type='text']:focus,
    input[type='email']:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
    }

    .reason-helper {
        margin: var(--space-xs) 0 0;
        padding: var(--space-xs) var(--space-sm);
        border-left: 3px solid var(--color-accent);
        border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
        font-style: italic;
    }

    /* Custom select arrow, colored via CSS variables (a background-image SVG couldn't be) */
    .select-wrapper {
        position: relative;
    }

    .select-wrapper::after {
        content: '▾';
        position: absolute;
        right: var(--space-sm);
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-accent);
        pointer-events: none;
    }

    select {
        appearance: none;
        padding-right: var(--space-lg);
        cursor: var(--cursor-pointer);
    }

    textarea {
        resize: vertical;
        min-height: 100px;
    }

    #githubIssueButtonContainer {
        text-align: center;
        margin-top: var(--space-md);
    }

    .form-status {
        margin: var(--space-md) 0 0;
        padding: var(--space-xs) var(--space-sm);
        border-radius: var(--border-radius-sm);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
    }

    .form-status.success {
        background: color-mix(in srgb, #22c55e 20%, transparent);
        color: #22c55e;
    }

    .form-status.error {
        background: color-mix(in srgb, #ef4444 20%, transparent);
        color: #ef4444;
    }

    @media (max-width: 480px) {
        .contact-form-container {
            padding: var(--space-md);
        }
    }
</style>
