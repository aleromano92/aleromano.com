---
import type { SupportedLanguage } from '../../types/i18n';

export interface ContactTranslations {
    pageTitle: string;
    pageDescription: string;
    formLabels: {
        reason: string;
        blogPostTitle: string;
        name: string;
        email: string;
        message: string;
    };
    reasonOptions: {
        select: string;
        problems: string;
        consultancy: string;
        mentoring: string;
        job: string;
        blogpost: string;
        general: string;
    };
    buttons: {
        submit: string;
        submitting: string;
        openGitHubIssue: string;
    };
    prefillMessages: {
        consultancy: string;
        mentoring: string;
        job: string;
        blogpost: string;
    };
    alerts: {
        success: string;
        error: string;
        networkError: string;
        emailSyntax: string;
        emailDomain: string;
    };
}

export const contactTranslations: Record<SupportedLanguage, ContactTranslations> = {
    en: {
        pageTitle: 'Contact',
        pageDescription:
            'Get in touch with Alessandro Romano for consultancy, mentoring, job opportunities, or general inquiries about software engineering and leadership.',
        formLabels: {
            reason: 'Reason',
            blogPostTitle: 'Blog Post Title',
            name: 'Name',
            email: 'Email',
            message: 'Message',
        },
        reasonOptions: {
            select: 'Select a reason...',
            problems: 'Problems on the website',
            consultancy: 'Consultancy request',
            mentoring: 'Mentoring',
            job: 'Job opportunities',
            blogpost: 'Blog Post Feedback',
            general: 'General inquiry',
        },
        buttons: {
            submit: 'Submit',
            submitting: 'Submitting...',
            openGitHubIssue: 'Open GitHub Issue',
        },
        prefillMessages: {
            consultancy:
                'Before reaching out, please review my LinkedIn profile (https://www.linkedin.com/in/aleromano92/). Then tell me why you think I could help your company, with a link for more details.',
            mentoring: "Tell me why you think I could be of help and I'll happily do my best.",
            job: 'Before reaching out, please review my LinkedIn profile (https://www.linkedin.com/in/aleromano92/). Then tell me why I could be a good fit, with a link for more details.',
            blogpost: 'Share your thoughts, feedback, or questions about this post — I appreciate constructive discussions!',
        },
        alerts: {
            success: 'Your message has been sent successfully!',
            error: 'An error occurred. Please try again.',
            networkError: 'An unexpected error occurred. Please check your connection and try again.',
            emailSyntax: "That email address doesn't look right. Please double-check it.",
            emailDomain: "That email's domain doesn't seem to receive mail. Is it spelled correctly?",
        },
    },
    it: {
        pageTitle: 'Contatti',
        pageDescription:
            'Contatta Alessandro Romano per consulenza, mentoring, opportunità di lavoro o domande generali su ingegneria del software e leadership.',
        formLabels: {
            reason: 'Motivo',
            blogPostTitle: 'Titolo del Post',
            name: 'Nome',
            email: 'Email',
            message: 'Messaggio',
        },
        reasonOptions: {
            select: 'Seleziona un motivo...',
            problems: 'Problemi sul sito web',
            consultancy: 'Richiesta di consulenza',
            mentoring: 'Mentoring',
            job: 'Opportunità di lavoro',
            blogpost: 'Feedback su articolo',
            general: 'Domanda generale',
        },
        buttons: {
            submit: 'Invia',
            submitting: 'Invio in corso...',
            openGitHubIssue: 'Apri Issue su GitHub',
        },
        prefillMessages: {
            consultancy:
                "Prima di contattarmi, dai un'occhiata al mio profilo LinkedIn (https://www.linkedin.com/in/aleromano92/). Poi scrivimi perché pensi che potrei aiutare la tua azienda, con un link per approfondire.",
            mentoring: "Scrivimi perché pensi che potrei esserti d'aiuto e farò del mio meglio.",
            job: "Prima di contattarmi, dai un'occhiata al mio profilo LinkedIn (https://www.linkedin.com/in/aleromano92/). Poi scrivimi perché sarei adatto alla tua azienda, con un link per approfondire.",
            blogpost:
                'Condividi pensieri, feedback o domande su questo articolo — apprezzo confronti costruttivi e discussioni interessanti!',
        },
        alerts: {
            success: 'Il tuo messaggio è stato inviato con successo!',
            error: 'Si è verificato un errore. Riprova.',
            networkError: 'Si è verificato un errore imprevisto. Controlla la connessione e riprova.',
            emailSyntax: "Quell'indirizzo email non sembra corretto. Ricontrollalo.",
            emailDomain: "Il dominio di quell'email non sembra ricevere posta. È scritto correttamente?",
        },
    },
};

export function getContactTranslations(language: SupportedLanguage): ContactTranslations {
    return contactTranslations[language];
}

interface Props {
    language: SupportedLanguage;
}

const { language } = Astro.props;

// Get translations for the current language
const t = getContactTranslations(language);

// Only what the client-side script needs; serialized on the container element
const clientTexts = {
    helpers: t.prefillMessages,
    submitLabel: t.buttons.submit,
    submittingLabel: t.buttons.submitting,
    messages: t.alerts,
};
---

<div class="contact-form-container" data-texts={JSON.stringify(clientTexts)}>
    <form id="contactForm">
        <div class="form-group">
            <label for="contactReason">{t.formLabels.reason}</label>
            <div class="select-wrapper">
                <select id="contactReason" name="reason">
                    <option value="">{t.reasonOptions.select}</option>
                    <option value="problems">{t.reasonOptions.problems}</option>
                    <option value="consultancy">{t.reasonOptions.consultancy}</option>
                    <option value="mentoring">{t.reasonOptions.mentoring}</option>
                    <option value="job">{t.reasonOptions.job}</option>
                    <option value="blogpost">{t.reasonOptions.blogpost}</option>
                    <option value="general">{t.reasonOptions.general}</option>
                </select>
            </div>
            <p id="reasonHelper" class="reason-helper" hidden></p>
        </div>

        <div class="form-group" id="blogPostTitleGroup" style="display: none;">
            <label for="blogPostTitle">{t.formLabels.blogPostTitle}</label>
            <input type="text" id="blogPostTitle" name="blogPostTitle" />
        </div>

        <fieldset id="formFields" disabled>
            <!-- Honeypot: humans never see it; the API requires it present and empty -->
            <div class="contact-extra" aria-hidden="true">
                <label for="website">Website</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-group">
                <label for="name">{t.formLabels.name}</label>
                <input type="text" id="name" name="name" required />
            </div>

            <div class="form-group">
                <label for="email">{t.formLabels.email}</label>
                <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
                <label for="message">{t.formLabels.message}</label>
                <textarea id="message" name="message" rows="5" required></textarea>
            </div>

            <button type="submit" class="button">{t.buttons.submit}</button>
        </fieldset>
    </form>

    <div id="githubIssueButtonContainer" style="display: none;">
        <a
            href="https://github.com/aleromano92/aleromano.com/issues/new"
            target="_blank"
            rel="noopener noreferrer"
            class="button"
        >
            {t.buttons.openGitHubIssue}
        </a>
    </div>

    <p id="formStatus" class="form-status" role="status" hidden></p>
</div>

<script>
    import {
        getReasonView,
        linkifyUrls,
        buildSubmissionPayload,
        parseReasonPreselection,
        fetchContactToken,
        submitWithTokenRecovery,
        type SubmitMessages,
    } from './contact-form';

    interface ClientTexts {
        helpers: Record<string, string>;
        submitLabel: string;
        submittingLabel: string;
        messages: SubmitMessages;
    }

    const container = document.querySelector<HTMLElement>('.contact-form-container');
    if (container) initContactForm(container);

    function initContactForm(root: HTMLElement): void {
        const texts: ClientTexts = JSON.parse(root.dataset.texts ?? '{}');

        const form = root.querySelector<HTMLFormElement>('#contactForm')!;
        const reasonSelect = root.querySelector<HTMLSelectElement>('#contactReason')!;
        const formFields = root.querySelector<HTMLFieldSetElement>('#formFields')!;
        const blogPostTitleGroup = root.querySelector<HTMLElement>('#blogPostTitleGroup')!;
        const blogPostTitleInput = root.querySelector<HTMLInputElement>('#blogPostTitle')!;
        const githubIssueContainer = root.querySelector<HTMLElement>('#githubIssueButtonContainer')!;
        const reasonHelper = root.querySelector<HTMLElement>('#reasonHelper')!;
        const formStatus = root.querySelector<HTMLElement>('#formStatus')!;
        const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;

        function showStatus(message: string, type: 'success' | 'error'): void {
            formStatus.textContent = message;
            formStatus.classList.remove('success', 'error');
            formStatus.classList.add(type);
            formStatus.hidden = false;
        }

        function hideStatus(): void {
            formStatus.hidden = true;
            formStatus.textContent = '';
        }

        function renderHelper(reason: string): void {
            const helperText = texts.helpers[reason];
            reasonHelper.hidden = !helperText;
            reasonHelper.innerHTML = helperText ? linkifyUrls(helperText) : '';
        }

        // Only toggles what is enabled/visible for the reason; never touches what the user typed
        function applyReason(reason: string): void {
            const view = getReasonView(reason);
            formFields.style.display = view.showForm ? '' : 'none';
            formFields.disabled = !view.enableForm;
            githubIssueContainer.style.display = view.showGithubIssue ? 'block' : 'none';
            blogPostTitleGroup.style.display = view.showBlogPostTitle ? 'block' : 'none';
            renderHelper(reason);
        }

        function resetForm(): void {
            form.reset();
            reasonSelect.value = '';
            applyReason('');
        }

        function setSubmitting(submitting: boolean): void {
            submitButton.disabled = submitting;
            submitButton.textContent = submitting ? texts.submittingLabel : texts.submitLabel;
        }

        // Form Token: fetched on first interaction so it is already past its
        // minimum age by the time a human finishes typing.
        let tokenPromise: Promise<string | null> | null = null;
        function ensureToken(): Promise<string | null> {
            tokenPromise ??= fetchContactToken();
            return tokenPromise;
        }
        form.addEventListener('focusin', ensureToken, { once: true });

        reasonSelect.addEventListener('change', () => {
            hideStatus();
            ensureToken();
            applyReason(reasonSelect.value);
        });

        form.addEventListener('submit', async (event) => {
            event.preventDefault();
            hideStatus();
            setSubmitting(true);

            const payload = buildSubmissionPayload(Object.fromEntries(new FormData(form)));
            const token = await ensureToken();
            const outcome = await submitWithTokenRecovery(payload, token, texts.messages);
            if (outcome.code === 'invalid-token') tokenPromise = null;

            setSubmitting(false);
            if (outcome.success) resetForm();
            showStatus(outcome.message, outcome.success ? 'success' : 'error');
        });

        const preselection = parseReasonPreselection(window.location.search);
        if (preselection) {
            reasonSelect.value = preselection.reason;
            if (preselection.blogPostTitle) blogPostTitleInput.value = preselection.blogPostTitle;
        }
        applyReason(reasonSelect.value);
    }
</script>

<style>
    @import '../../styles/buttons.css';

    .contact-form-container {
        max-width: 600px;
        margin: var(--space-lg) auto;
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        border-radius: var(--border-radius);
        padding: var(--space-lg);
        color: var(--color-text);
    }

    fieldset {
        border: none;
        padding: 0;
        margin: 0;
        transition: opacity 0.3s ease;
    }

    fieldset:disabled {
        opacity: 0.45;
    }

    .form-group {
        margin-bottom: var(--space-md);
    }

    /* Honeypot: moved off-screen rather than display:none, which naive bots detect */
    .contact-extra {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
    }

    label {
        display: block;
        margin-bottom: var(--space-xs);
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-sm);
        color: var(--color-text-primary);
    }

    input[type='text'],
    input[type='email'],
    select,
    textarea {
        width: 100%;
        padding: var(--space-xs) var(--space-sm);
        border: 1px solid var(--color-border-light);
        border-radius: var(--border-radius-sm);
        background-color: var(--color-bg);
        color: var(--color-text);
        font: inherit;
        line-height: var(--line-height-base);
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    input[type='text']:hover,
    input[type='email']:hover,
    select:hover,
    textarea:hover {
        border-color: var(--color-accent);
    }

    input[type='text']:focus,
    input[type='email']:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
    }

    /* Native validation: flag fields only after the user has interacted with them */
    input:user-invalid,
    textarea:user-invalid {
        border-color: var(--color-error);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-error) 25%, transparent);
    }

    .reason-helper {
        margin: var(--space-xs) 0 0;
        padding: var(--space-xs) var(--space-sm);
        border-left: 3px solid var(--color-accent);
        border-radius: 0 var(--border-radius-sm) var(--border-radius-sm) 0;
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
        font-style: italic;
    }

    /* Custom select arrow, colored via CSS variables (a background-image SVG couldn't be) */
    .select-wrapper {
        position: relative;
    }

    .select-wrapper::after {
        content: '▾';
        position: absolute;
        right: var(--space-sm);
        top: 50%;
        transform: translateY(-50%);
        color: var(--color-accent);
        pointer-events: none;
    }

    select {
        appearance: none;
        padding-right: var(--space-lg);
        cursor: var(--cursor-pointer);
    }

    textarea {
        resize: vertical;
        min-height: 100px;
    }

    #githubIssueButtonContainer {
        text-align: center;
        margin-top: var(--space-md);
    }

    .form-status {
        margin: var(--space-md) 0 0;
        padding: var(--space-xs) var(--space-sm);
        border-radius: var(--border-radius-sm);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-bold);
    }

    .form-status.success {
        background: color-mix(in srgb, var(--color-success) 20%, transparent);
        color: var(--color-success);
    }

    .form-status.error {
        background: color-mix(in srgb, var(--color-error) 20%, transparent);
        color: var(--color-error);
    }

    @media (max-width: 480px) {
        .contact-form-container {
            padding: var(--space-md);
        }
    }
</style>
