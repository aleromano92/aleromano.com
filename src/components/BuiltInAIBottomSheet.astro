---
// Bottom sheet overlay for displaying AI-generated content (summary or translation)
// Opened programmatically via window.openAIBottomSheet({ title, stream })
---

<div id="ai-bottom-sheet" class="bottom-sheet" role="dialog" aria-modal="true" aria-labelledby="ai-sheet-title" hidden>
  <div class="backdrop" id="ai-sheet-backdrop"></div>
  <div class="sheet">
    <div class="sheet-handle"></div>
    <div class="sheet-header">
      <h2 id="ai-sheet-title" class="sheet-title"></h2>
      <button class="sheet-close" id="ai-sheet-close" aria-label="Close">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="sheet-content" id="ai-sheet-content">
      <div class="loading" id="ai-sheet-loading" hidden>
        <span class="loading-dot"></span>
        <span class="loading-dot"></span>
        <span class="loading-dot"></span>
      </div>
      <div id="ai-sheet-text" class="sheet-text"></div>
    </div>
    <div class="sheet-footer">
      <small>
        Powered by <a href="https://developer.chrome.com/docs/ai/built-in" target="_blank" rel="noopener noreferrer"
          >Chrome Built-in AI</a
        > — runs on your device
      </small>
    </div>
  </div>
</div>

<style>
  .bottom-sheet {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: flex-end;
    pointer-events: none;
  }

  .bottom-sheet:not([hidden]) {
    pointer-events: auto;
  }

  .backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .bottom-sheet:not([hidden]) .backdrop {
    opacity: 1;
  }

  .sheet {
    position: relative;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    background: var(--color-bg);
    border-radius: 16px 16px 0 0;
    border: 1px solid var(--color-border-light);
    border-bottom: none;
    max-height: 65vh;
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
    box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.15);
  }

  .bottom-sheet:not([hidden]) .sheet {
    transform: translateY(0);
  }

  .sheet-handle {
    width: 40px;
    height: 4px;
    background: var(--color-border-light);
    border-radius: 2px;
    margin: 12px auto 0;
    flex-shrink: 0;
  }

  .sheet-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--space-md);
    flex-shrink: 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .sheet-title {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    margin: 0;
    color: var(--color-text);
  }

  .sheet-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 4px;
    border-radius: 4px;
    display: flex;
    align-items: center;
    transition:
      color 0.2s,
      background 0.2s;
  }

  .sheet-close:hover {
    color: var(--color-text);
    background: var(--color-secondary);
  }

  .sheet-content {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-md);
    -webkit-overflow-scrolling: touch;
  }

  .loading {
    display: flex;
    gap: 6px;
    justify-content: center;
    padding: var(--space-lg);
  }

  /* Prevent display:flex from overriding the [hidden] attribute */
  .loading[hidden] {
    display: none;
  }

  .loading-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: bounce 1.2s ease-in-out infinite;
  }

  .loading-dot:nth-child(2) {
    animation-delay: 0.2s;
  }
  .loading-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes bounce {
    0%,
    80%,
    100% {
      transform: scale(0.6);
      opacity: 0.5;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .sheet-text {
    line-height: 1.7;
    color: var(--color-text);
    white-space: pre-wrap;
  }

  /* Rendered markdown styles */
  .sheet-text :global(p) {
    margin: 0 0 var(--space-sm);
  }

  .sheet-text :global(p:last-child) {
    margin-bottom: 0;
  }

  .sheet-text :global(ul),
  .sheet-text :global(ol) {
    padding-left: var(--space-md);
    margin: 0 0 var(--space-sm);
  }

  .sheet-text :global(li) {
    margin-bottom: var(--space-xs);
  }

  .sheet-text :global(h1),
  .sheet-text :global(h2),
  .sheet-text :global(h3) {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    margin: var(--space-sm) 0 var(--space-xs);
  }

  .sheet-text :global(strong) {
    font-weight: var(--font-weight-bold);
  }

  .sheet-footer {
    padding: var(--space-xs) var(--space-md) var(--space-sm);
    flex-shrink: 0;
    border-top: 1px solid var(--color-border-light);
    color: var(--color-text-secondary);
  }

  .sheet-footer a {
    color: var(--color-text-secondary);
  }

  @media (max-width: 480px) {
    .sheet {
      max-height: 75vh;
      border-radius: 12px 12px 0 0;
    }
  }
</style>

<script>
  import { marked } from 'marked';
  import { trackEvent } from '../scripts/analytics';

  const sheet = document.getElementById('ai-bottom-sheet') as HTMLElement;
  const backdrop = document.getElementById('ai-sheet-backdrop') as HTMLElement;
  const closeBtn = document.getElementById('ai-sheet-close') as HTMLButtonElement;
  const titleEl = document.getElementById('ai-sheet-title') as HTMLElement;
  const sheetContent = document.getElementById('ai-sheet-content') as HTMLElement;
  const contentEl = document.getElementById('ai-sheet-text') as HTMLElement;
  const loadingEl = document.getElementById('ai-sheet-loading') as HTMLElement;

  let currentController: AbortController | null = null;

  function renderMarkdown(text: string) {
    contentEl.innerHTML = marked.parse(text) as string;
    sheetContent.scrollTop = sheetContent.scrollHeight;
  }

  function openSheet(title: string) {
    titleEl.textContent = title;
    contentEl.innerHTML = '';
    loadingEl.hidden = false;
    sheet.hidden = false;

    requestAnimationFrame(() => {
      sheet.classList.add('open');
    });

    closeBtn.focus();
  }

  function closeSheet() {
    sheet.hidden = true;
    sheet.classList.remove('open');
    currentController?.abort();
    currentController = null;
  }

  async function streamContent(stream: ReadableStream<string>, mode: 'replace' | 'append', feature: string) {
    contentEl.innerHTML = '';

    const reader = stream.getReader();
    currentController = new AbortController();
    let accumulated = '';

    try {
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        if (currentController.signal.aborted) break;

        loadingEl.hidden = true;

        if (mode === 'replace') {
          accumulated = value;
        } else {
          accumulated += value;
        }
        renderMarkdown(accumulated);
      }

      if (accumulated) {
        trackEvent({
          type: 'ai_feature',
          path: window.location.pathname,
          elementId: 'ai-feature-completed',
          elementText: feature,
        });
      }
    } catch (err: any) {
      if (err?.name !== 'AbortError') {
        contentEl.textContent = 'Something went wrong. The AI model may not be ready yet. Please try again.';
      }
    } finally {
      reader.releaseLock();
    }
  }

  // Public API — called from BuiltInAICallout
  (window as any).openAIBottomSheet = async (options: {
    title: string;
    stream: ReadableStream<string>;
    mode: 'replace' | 'append';
    feature: string;
  }) => {
    openSheet(options.title);
    await streamContent(options.stream, options.mode, options.feature);
  };

  // Close triggers
  closeBtn.addEventListener('click', closeSheet);
  backdrop.addEventListener('click', closeSheet);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !sheet.hidden) closeSheet();
  });
</script>
